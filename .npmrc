# @n8n/eslint-plugin-community-nodes declares an aspirational `n8n-workflow >=2`
# peer; n8n actually ships n8n-workflow 1.x, which we pin for dev. Accept the
# mismatch so `npm install` / `npm ci` resolve (the plugin is dev-only tooling).
legacy-peer-deps=true
# n8n-workflow pulls `isolated-vm` (native, needs Node >=22 to compile) but only
# lazy-loads it — never exercised by our build/test/lint. Skip native builds so
# `npm ci` works on Node 20 runners. `npm run build` is invoked explicitly, so
# this does not affect the actual build.
ignore-scripts=true
