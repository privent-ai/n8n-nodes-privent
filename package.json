{
  "name": "n8n-nodes-privent",
  "version": "1.0.0",
  "description": "Privent DLP nodes for n8n: session-scoped tokenization, risk scoring, and safe detokenization for AI agent workflows",
  "homepage": "https://www.privent.ai/docs",
  "author": "Privent AI <hello@privent.ai>",
  "license": "MIT",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/privent-ai/n8n-nodes-privent.git"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup && node scripts/copy-assets.cjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint dist/**/*.js package.json",
    "lint:fix": "eslint dist/**/*.js package.json --fix",
    "loadability": "node scripts/check-loadability.mjs"
  },
  "keywords": [
    "n8n-community-node-package",
    "privent",
    "security",
    "pii",
    "dlp",
    "ai",
    "agent",
    "tokenization",
    "data-loss-prevention"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "nodes": [
      "dist/nodes/PriventSession/PriventSession.node.js",
      "dist/nodes/PriventTokenize/PriventTokenize.node.js",
      "dist/nodes/PriventDetokenize/PriventDetokenize.node.js",
      "dist/nodes/PriventRiskCheck/PriventRiskCheck.node.js",
      "dist/nodes/PriventAuditEvent/PriventAuditEvent.node.js",
      "dist/nodes/PriventHandoff/PriventHandoff.node.js"
    ],
    "credentials": [
      "dist/credentials/PriventApi.credentials.js"
    ]
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@n8n/eslint-plugin-community-nodes": "^0.21",
    "@priventai/core": "^0.8.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^9.29.0",
    "n8n-workflow": "^1.73.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.0"
  }
}
